{
  "name": "traveller-guide-monorepo",
  "version": "1.0.0",
  "packageManager": "npm@11.6.2",
  "private": true,
  "description": "Umrah Pilgrim Management System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "prettier": "^3.2.5"
  }
}